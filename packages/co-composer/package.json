{
  "name": "@neo-fm/co-composer",
  "version": "0.0.0",
  "private": true,
  "description": "Style-aware co-composition modules (western, carnatic, hindustani, kannada-folk). Interface only at Phase 0.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc -b tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "build-phase-2-request": "tsx scripts/build-phase-2-request.ts"
  },
  "dependencies": {
    "@neo-fm/song-doc": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
