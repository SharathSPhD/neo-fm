{
  "$ref": "#/definitions/SongDocument",
  "definitions": {
    "SongDocument": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "user_id": {
          "type": "string",
          "format": "uuid"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "language": {
          "type": "string",
          "enum": [
            "en",
            "hi",
            "kn",
            "ta",
            "bn",
            "te",
            "sa"
          ]
        },
        "style_family": {
          "type": "string",
          "enum": [
            "western",
            "carnatic",
            "hindustani",
            "kannada-folk",
            "kannada-light-classical",
            "tamil-folk",
            "bollywood-ballad",
            "sanskrit-shloka",
            "bengali-rabindrasangeet",
            "telugu-keerthana"
          ]
        },
        "tempo_bpm": {
          "type": "integer",
          "minimum": 30,
          "maximum": 240
        },
        "time_signature": {
          "type": "string"
        },
        "tala": {
          "type": "string"
        },
        "target_duration_seconds": {
          "type": "number",
          "enum": [
            30,
            60,
            90,
            180
          ]
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1,
                "maxLength": 64
              },
              "type": {
                "type": "string",
                "enum": [
                  "intro",
                  "verse",
                  "chorus",
                  "bridge",
                  "outro",
                  "pallavi",
                  "anupallavi",
                  "charanam",
                  "mukhda",
                  "antara",
                  "saranam",
                  "alaap",
                  "sargam",
                  "folk_refrain",
                  "folk_stanza",
                  "shloka_verse",
                  "shloka_refrain",
                  "phalashruti"
                ]
              },
              "lyrics": {
                "type": "string",
                "maxLength": 1000
              },
              "script": {
                "type": "string",
                "enum": [
                  "latin",
                  "devanagari",
                  "tamil",
                  "kannada",
                  "telugu",
                  "bengali"
                ]
              },
              "transliteration": {
                "type": "string"
              },
              "swara_sequence": {
                "type": "string"
              },
              "phonemes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "target_seconds": {
                "type": "integer",
                "minimum": 1,
                "maximum": 360
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "id",
              "type",
              "target_seconds"
            ],
            "additionalProperties": false
          },
          "minItems": 1
        },
        "orchestration": {
          "type": "object",
          "properties": {
            "lead_vocal": {
              "type": "string",
              "enum": [
                "male",
                "female",
                "instrumental"
              ]
            },
            "instruments": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "texture": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "raga": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "system": {
              "type": "string",
              "enum": [
                "carnatic",
                "hindustani",
                "light-classical",
                "folk"
              ]
            },
            "arohana": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "avarohana": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "nyas": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "pakad": {
              "type": "string"
            }
          },
          "required": [
            "name",
            "system"
          ],
          "additionalProperties": false
        },
        "voice_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "background_mix": {
          "type": "object",
          "properties": {
            "accompaniment_density": {
              "type": "string",
              "enum": [
                "sparse",
                "balanced",
                "dense"
              ]
            },
            "dynamics": {
              "type": "string",
              "enum": [
                "calm",
                "balanced",
                "energetic"
              ]
            },
            "brightness": {
              "type": "string",
              "enum": [
                "dark",
                "neutral",
                "bright"
              ]
            },
            "reverb": {
              "type": "string",
              "enum": [
                "dry",
                "room",
                "hall",
                "cathedral"
              ]
            }
          },
          "additionalProperties": false
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {}
        }
      },
      "required": [
        "language",
        "style_family",
        "target_duration_seconds",
        "sections"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
