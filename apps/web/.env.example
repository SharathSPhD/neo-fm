# apps/web environment

# --- Supabase (auto-provisioned by the Vercel <> Supabase Marketplace
#     integration; needed locally for `pnpm --filter @neo-fm/web dev`) ---
NEXT_PUBLIC_SUPABASE_URL=https://lsxicfgqtdxvlcivlwmd.supabase.co
# Either name works; the integration sets ANON_KEY. Newer Supabase projects
# call it the "publishable" key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only; NEVER expose to the browser bundle.
SUPABASE_SERVICE_ROLE_KEY=

# --- Feature flags ---
# Prompt branch (Describe with AI tab) is live in v1.5. Set to "false"
# for emergency rollback only; omitting this var defaults to enabled.
# NEO_FM_PROMPT_BRANCH_ENABLED=false

# Email notifications (Resend)
RESEND_API_KEY=re_...
APP_URL=https://neo-fm-web.vercel.app
