{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neo-fm.example.com/contracts/queue-message.schema.json",
  "title": "SongGenerationJob",
  "description": "Queue message body for the pgmq `song_generation_jobs` queue. Producer: Next.js API (`POST /api/songs`). Consumer: `services/dgx-worker`.",
  "type": "object",
  "required": [
    "job_id",
    "user_id",
    "song_document_id",
    "priority",
    "created_at",
    "style_family",
    "target_duration_seconds"
  ],
  "properties": {
    "job_id": {
      "type": "string",
      "format": "uuid",
      "description": "primary key in `jobs` table"
    },
    "user_id": {
      "type": "string",
      "format": "uuid"
    },
    "song_document_id": {
      "type": "string",
      "format": "uuid",
      "description": "primary key in `song_documents` table; worker fetches full doc from Supabase using this id"
    },
    "priority": {
      "type": "string",
      "enum": ["normal", "high"],
      "default": "normal"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "style_family": {
      "type": "string",
      "enum": ["western", "carnatic", "hindustani", "kannada-folk"]
    },
    "target_duration_seconds": {
      "type": "integer",
      "enum": [30, 60, 90, 180]
    },
    "tier": {
      "type": "string",
      "enum": ["free", "creator", "pro"],
      "description": "used by `MusicEngine` router in Phase 12 to pick HeartMuLa vs Lyria"
    },
    "trace_id": {
      "type": "string",
      "description": "OpenTelemetry-style trace id; surfaces in logs and Grafana (Phase 11)"
    }
  },
  "additionalProperties": false
}
