# neo-fm — DGX-side environment variables.
#
# Copy to infra/.env.dgx and fill in real values. NEVER commit the real file.
# The included scripts/dgx-bootstrap.sh writes this file for you, prompting
# for any value not already in the operator's shell env.

# ----- HMAC (ADR 0003) ------------------------------------------------------
# Shared secret for HMAC-SHA256 between dgx-worker and music-inference.
# Generate with: openssl rand -hex 32  (32 bytes / 64 hex chars).
# The Phase 4 commit set the canonical value as a GitHub Actions secret
# `MUSIC_INFERENCE_HMAC_SECRET` on SharathSPhD/neo-fm; pasting that here
# keeps the worker, server, and any future CI smoke test agreed.
MUSIC_INFERENCE_HMAC_SECRET=

# Second valid secret during rotation. Server accepts either. Leave blank
# when you're not in the middle of a rotation.
MUSIC_INFERENCE_HMAC_SECRET_NEXT=

# ----- Internal URL --------------------------------------------------------
# Both containers share the docker-compose `neo-fm` network, so the worker
# reaches the inference service on the bridge hostname. There is no
# Tailscale hop -- the dgx-worker only talks to (a) music-inference on
# the compose network and (b) Supabase over public TLS. See PHASE-4-HANDOFF
# §4 for the architectural rationale.
MUSIC_INFERENCE_URL=http://music-inference:8000

# ----- Supabase (Phase 4+) -------------------------------------------------
# Public Supabase URL (`https://<ref>.supabase.co`). Used by the worker for
# the Storage API (signed PUTs into the private `tracks` bucket).
SUPABASE_URL=https://lsxicfgqtdxvlcivlwmd.supabase.co

# Service-role key. SERVER-ONLY. The worker uses this *only* for Storage
# uploads; SQL goes through the dedicated neo_fm_worker Postgres role
# below (ADR 0004). Never expose this in the cloud API client bundle.
SUPABASE_SERVICE_ROLE_KEY=

# ----- Postgres (neo_fm_worker role, ADR 0004) -----------------------------
# Connection string used by services/dgx-worker. Connect via the Supabase
# transaction pooler (`*.pooler.supabase.com:6543`) so pgmq operations
# don't burn idle connections. The `neo_fm_worker` role has column-level
# UPDATE on jobs + INSERT on tracks + full pgmq surface, and an explicit
# REVOKE on users/subscriptions.
#
# Format (transaction pooler):
#   postgresql://neo_fm_worker.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres
PG_DSN=

# ----- Queue / lease tuning (ADR 0008) -------------------------------------
QUEUE_NAME=song_generation_jobs
DLQ_NAME=song_generation_jobs_dlq
VISIBILITY_TIMEOUT_SECONDS=300
HEARTBEAT_INTERVAL_SECONDS=60
POLL_INTERVAL_SECONDS=5
MAX_ATTEMPTS=3

# ----- HF (Phase 1 model bring-up) -----------------------------------------
# Required by services/music-inference when downloading HeartMuLa weights.
# Gated public token from https://huggingface.co/settings/tokens (read scope
# only). Not needed after weights are persisted on /mnt/models, but harmless
# to leave set.
HF_TOKEN=

# Path inside the container where HeartMuLa weights live. Must match the
# `volumes:` mount in infra/docker-compose.dgx.yml.
HEARTMULA_CKPT_DIR=/mnt/models/heartmula

# ----- vocal-synth (Sprint 5) ----------------------------------------------
# Shared secret for HMAC-SHA256 between dgx-worker and vocal-synth.
# Generate with: openssl rand -hex 32
VOCAL_SYNTH_HMAC_SECRET=

# Second valid secret during rotation. Leave blank outside a rotation.
VOCAL_SYNTH_HMAC_SECRET_NEXT=

# URL the worker uses to reach vocal-synth. Leave empty to disable vocal
# synthesis (worker stays instrumental-only and ships the HeartMuLa render
# straight to Storage).
VOCAL_SYNTH_URL=http://vocal-synth:8089

# Comma-separated list of languages to render per job. Each language
# becomes one parallel /v1/vocalize call; failed languages are logged
# but do NOT abort the job.
VOCAL_LANGUAGES=hi,kn,ta,te,bn

# Voice timbre forwarded to vocal-synth. One of: male, female, androgynous.
VOCAL_VOICE_TIMBRE=androgynous

# Per-call timeout (seconds) for the worker's HTTP call into vocal-synth.
VOCAL_SYNTH_TIMEOUT_SECONDS=300

# Backend selection for vocal-synth. One of: auto, fake, svara, parler.
# - `auto`  : real model if NEO_FM_REQUIRE_REAL_MODEL=1, else fake.
# - `svara` : kenpath/svara-tts-v1 (Indic SVS, recommended).
# - `parler`: ai4bharat/indic-parler-tts (fallback).
# - `fake`  : deterministic synthetic audio (CI / dev only).
VOCAL_MODEL_BACKEND=auto
VOCAL_MODEL_ID=kenpath/svara-tts-v1

# Force the real model to load. With this off, vocal-synth quietly
# falls back to the fake so local docker-compose still works without
# the GPU. Set to 1 on the real DGX node.
NEO_FM_REQUIRE_REAL_MODEL=0

# Disallow Hugging Face Hub downloads inside vocal-synth (used in CI
# images where weights are pre-baked).
NEO_FM_OFFLINE=0

# Where the vocal-synth container caches HF weights. Mount the host
# directory in docker-compose.dgx.yml `volumes:`.
VOCAL_HF_HOME=/var/cache/huggingface
VOCAL_HF_HOME_HOST=/var/cache/huggingface

# ----- GPU governor (Sprint 6 / ADR 0011) ----------------------------------
# Shared state file the operator CLI (`scripts/neo-fm-governor.py`)
# writes and the dgx-worker reads. Bind-mount the host directory into
# the worker container as a tmpfs or shared volume.
GOVERNOR_STATE_PATH=/var/run/neo-fm/governor.state

# How often the worker re-reads governor.state while paused. The
# worker only consults the state file BETWEEN jobs; this controls the
# pause-loop sleep when stop_new_jobs is true.
GOVERNOR_POLL_SECONDS=2
