# neo-fm — DGX-side environment variables.
#
# Copy to infra/.env.dgx and fill in real values. NEVER commit the real file.
#
# Per ADR 0003 (internal-API HMAC):
#   Generate with:
#     openssl rand -hex 32
#   The same secret must be set on both music-inference and dgx-worker.

# Required: shared secret for HMAC-SHA256 between dgx-worker and music-inference.
# Must be at least 32 bytes (64 hex chars). Rotate by setting MUSIC_INFERENCE_HMAC_SECRET_NEXT,
# flipping callers, then clearing the old one.
MUSIC_INFERENCE_HMAC_SECRET=

# Optional: second valid secret during rotation. Server accepts either.
MUSIC_INFERENCE_HMAC_SECRET_NEXT=

# Phase 4+ — Supabase Postgres connection for dgx-worker (uses neo_fm_worker role per ADR 0004).
# Leave blank until Phase 4.
# PGHOST=
# PGPORT=
# PGUSER=neo_fm_worker
# PGPASSWORD=
# PGDATABASE=
